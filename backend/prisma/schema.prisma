generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContentType {
  IMAGE
  VIDEO
  CAROUSEL
  UGC
  STORY
  REEL
}

enum CreatorType {
  INTERNAL
  FREELANCER
  AGENCY
  UGC_CREATOR
  PRODUCTION_HOUSE
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  LAUNCHED
  REJECTED
  EXPIRED
  NOT_USED
}

enum SubmissionStatus {
  PENDING_VALIDATION
  VALIDATED
  REJECTED
}

enum AccessLevel {
  ADMIN
  MANAGER
  READ_ONLY
}

enum MatchType {
  DIRECT_MATCH
  IMAGE_HASH
  VIDEO_ID
  VISUAL_AI_MATCH
  MANUAL_MATCH
}

model Organization {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  industry String?
  website  String?

  status Status @default(ACTIVE)

  brands Brand[]
  users  User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     Role[]
}

model Brand {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name     String
  industry String?
  website  String?

  status Status @default(ACTIVE)

  products Product[]
  creators Creator[]
  contents Content[]

  platformAccounts PlatformAccount[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  contentTags ContentTag[]
}

model User {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String
  email        String @unique
  passwordHash String

  status Status @default(ACTIVE)

  userRoles UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  description String?

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id String @id @default(uuid())

  code        String  @unique
  description String?

  rolePermissions RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Product {
  id String @id @default(uuid())

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  name     String
  category String?
  sku      String?

  status Status @default(ACTIVE)

  contents Content[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Creator {
  id String @id @default(uuid())

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  name  String
  email String?

  creatorType CreatorType

  contents Content[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Content {
  id String @id @default(uuid())

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  creatorId String?
  creator   Creator? @relation(fields: [creatorId], references: [id])

  contentCode String @unique

  name String

  contentType ContentType

  language String?
  format   String?

  aspectRatio     String?
  durationSeconds Int?

  status Status @default(ACTIVE)

  assets      ContentAsset[]
  assignments ContentAssignment[]
  mappings    ContentPlatformMapping[]

  tags ContentTagMapping[]

  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  performanceFactDailies PerformanceFactDaily[]
}

model ContentAsset {
  id String @id @default(uuid())

  contentId String
  content   Content @relation(fields: [contentId], references: [id])

  fileUrl      String
  thumbnailUrl String?

  mimeType String?
  fileSize Int?

  sha256Hash     String?
  perceptualHash String?

  videoFingerprint String?

  width  Int?
  height Int?

  createdAt DateTime @default(now())
}

model ContentTag {
  id String @id @default(uuid())

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  name        String
  description String?

  mappings ContentTagMapping[]

  createdAt DateTime @default(now())

  @@unique([brandId, name])
}

model ContentTagMapping {
  contentId String
  tagId     String

  content Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     ContentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
}

model Agency {
  id String @id @default(uuid())

  name   String
  region String?

  contactName  String?
  contactEmail String?

  status Status @default(ACTIVE)

  assignments     ContentAssignment[]
  accountAccesses AgencyAccountAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentAssignment {
  id String @id @default(uuid())

  contentId String
  content   Content @relation(fields: [contentId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  platformId String
  platform   Platform @relation(fields: [platformId], references: [id])

  platformAccountId String
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  market String?

  assignedBy String?

  assignedDate DateTime

  launchDueDate DateTime?
  launchDate    DateTime?

  status AssignmentStatus

  notes String?

  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentId])
  @@index([agencyId])
  @@index([platformAccountId])
  @@index([status])
}

model AssignmentSubmission {
  id String @id @default(uuid())

  assignmentId String
  assignment   ContentAssignment @relation(fields: [assignmentId], references: [id])

  platformAccountId String
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  submittedBy String?

  externalAssetId    String?
  externalCampaignId String?

  submissionNotes String?

  status SubmissionStatus

  submittedAt DateTime?
  validatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignmentId])
  @@index([platformAccountId])
  @@index([status])
}

model ContentPlatformMapping {
  id String @id @default(uuid())

  contentId String
  content   Content @relation(fields: [contentId], references: [id])

  platformCreativeId String
  platformCreative   PlatformCreative @relation(fields: [platformCreativeId], references: [id])

  matchType MatchType

  confidenceScore Float?

  reviews ContentMatchReview[]

  createdAt DateTime @default(now())

  @@unique([contentId, platformCreativeId])
  @@index([contentId])
  @@index([platformCreativeId])
  @@index([matchType])
}

model ContentMatchReview {
  id String @id @default(uuid())

  mappingId String
  mapping   ContentPlatformMapping @relation(fields: [mappingId], references: [id])

  reviewStatus String

  reviewedBy String?
  reviewedAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@index([mappingId])
}

model PerformanceFactDaily {
  id String @id @default(uuid())

  date DateTime

  contentId String?
  content   Content? @relation(fields: [contentId], references: [id])

  platformAdId String
  platformAd   PlatformAd @relation(fields: [platformAdId], references: [id])

  spend Decimal @db.Decimal(18, 4)

  impressions Int @default(0)
  reach       Int @default(0)

  clicks Int @default(0)

  ctr Decimal? @db.Decimal(10, 4)
  cpc Decimal? @db.Decimal(18, 4)

  conversions Int @default(0)

  revenue Decimal? @db.Decimal(18, 4)
  roas    Decimal? @db.Decimal(18, 4)

  createdAt DateTime @default(now())

  @@unique([date, platformAdId])
  @@index([contentId])
  @@index([platformAdId])
  @@index([date])
}

model Platform {
  id String @id @default(uuid())

  name String
  code String @unique

  logoUrl String?

  isActive Boolean @default(true)

  accounts PlatformAccount[]

  createdAt          DateTime            @default(now())
  contentAssignments ContentAssignment[]
}

model PlatformAccount {
  id String @id @default(uuid())

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  platformId String
  platform   Platform @relation(fields: [platformId], references: [id])

  externalAccountId String
  accountName       String

  currency String?
  timezone String?

  status Status @default(ACTIVE)

  campaigns PlatformCampaign[]
  creatives PlatformCreative[]

  assignments ContentAssignment[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assignmentSubmissions AssignmentSubmission[]
  agencyAccountAccesses AgencyAccountAccess[]

  @@unique([platformId, externalAccountId])
  @@index([brandId])
  @@index([platformId])
}

model AgencyAccountAccess {
  id String @id @default(uuid())

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  platformAccountId String
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  accessLevel AccessLevel

  createdAt DateTime @default(now())

  @@unique([agencyId, platformAccountId])
}

model PlatformAd {
  id String @id @default(uuid())

  adGroupId String
  adGroup   PlatformAdGroup @relation(fields: [adGroupId], references: [id])

  externalAdId String

  name String

  status String?

  usages  AdCreativeUsage[]
  metrics PerformanceFactDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adGroupId, externalAdId])
  @@index([adGroupId])
}

model AdCreativeUsage {
  id String @id @default(uuid())

  platformAdId String
  platformAd   PlatformAd @relation(fields: [platformAdId], references: [id])

  platformCreativeId String
  platformCreative   PlatformCreative @relation(fields: [platformCreativeId], references: [id])

  isCurrent Boolean @default(true)

  firstSeenAt DateTime?
  lastSeenAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([platformAdId, platformCreativeId])
  @@index([platformAdId])
  @@index([platformCreativeId])
  @@index([isCurrent])
}

model PlatformCreative {
  id String @id @default(uuid())

  platformAccountId String
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  externalCreativeId String

  creativeName String?

  videoId   String?
  imageHash String?
  assetId   String?

  rawPayloadJson Json?

  version Int @default(1)

  mappings ContentPlatformMapping[]
  usages   AdCreativeUsage[]

  createdAt DateTime @default(now())

  @@unique([platformAccountId, externalCreativeId])
  @@index([videoId])
  @@index([imageHash])
}

model PlatformCampaign {
  id String @id @default(uuid())

  platformAccountId String
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  externalCampaignId String

  name String

  objective String?

  status String?

  startDate DateTime?
  endDate   DateTime?

  adGroups PlatformAdGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platformAccountId, externalCampaignId])
  @@index([platformAccountId])
  @@index([status])
}

model PlatformAdGroup {
  id String @id @default(uuid())

  campaignId String
  campaign   PlatformCampaign @relation(fields: [campaignId], references: [id])

  externalAdGroupId String

  name String

  status String?

  ads PlatformAd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, externalAdGroupId])
  @@index([campaignId])
}
